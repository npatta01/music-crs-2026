# Copy to .env and fill in values as needed.
#
# HuggingFace authentication
# Option A (recommended): run `uvx hf auth login` once — token stored system-wide
#   at ~/.cache/huggingface/token, no .env needed.
# Option B (CI / Modal): set HF_TOKEN here.
#
# HF_TOKEN=hf_...

# Override HuggingFace cache location (default: ~/.cache/huggingface/).
# Useful if the home partition is small.
#
# HF_HOME=/path/to/larger/disk/.cache/huggingface

# Required for any config that calls OpenRouter directly: the deepseek-v4-flash
# state extractor and the qwen3-30b response generator (explanation_lm_type/
# explanation_lm_kwargs in the blindset configs). Also required to start the
# optional local proxy, ./scripts/litellm-proxy (see docs/litellm_proxy.md).
OPENROUTER_API_KEY=sk-or-...

# ----- LiteLLM proxy (optional, see docs/litellm_proxy.md) -----

# Override the LiteLLM proxy base / key used by mcrs at runtime.
# Defaults: http://localhost:4000 and "sk-anything".
# LITELLM_PROXY_BASE=http://localhost:4000
# LITELLM_PROXY_KEY=sk-anything

# Override the proxy launcher's bind host/port and config path.
# LITELLM_PROXY_HOST=0.0.0.0
# LITELLM_PROXY_PORT=4000
# LITELLM_PROXY_CONFIG=configs/litellm_proxy.openrouter.yaml

# ----- LiteLLM disk cache (mcrs/litellm_cache.py) -----
# Every litellm.completion/batch_completion call (state extraction AND response
# generation) goes through ONE shared cache at this path — there is no separate
# variable per call site. Unset = no caching, every call is live.
#
# For general local dev, point this at a plain local directory that accumulates
# whatever you've run before. It grows over time and is NOT guaranteed to cover
# every call — a cache miss falls straight through to a live OpenRouter call, so
# don't assume "cache configured" means "zero cost."
MCRS_LITELLM_CACHE_DIR=cache/litellm-state
MCRS_LITELLM_CACHE_BACKEND=file

# For a guaranteed-zero-cost verification run instead (e.g. reproducing a
# specific submitted devset/Blind-A/Blind-B result), do NOT use the dev cache
# above — source the offline reproduction bundle's env instead, which points
# MCRS_LITELLM_CACHE_DIR at the curated, frozen cache/litellm-repro/ bundle and
# sets MCRS_REQUIRE_LITELLM_CACHE=1 (hard-fails loudly on any miss instead of
# silently calling the API):
#   source .repro/scripts/activate_repro_env.sh
# See docs/reproduce_offline_bundle.md. cache/litellm-repro only covers the
# exact calls needed for the canonical runs it was built from — a fresh rerun
# that reorders which track ranks #1 (ANN nondeterminism) can still need a
# live call for that track's explanation; that's expected, not a bug.

# DeepInfra — Qwen3-Embedding-0.6B query embeddings, $0.01/1M tokens.
# DEEPINFRA_API_KEY=...

# Shared bearer key for the self-hosted vLLM embedding endpoints (modal/vllm_serve.py).
VLLM_API_KEY=change-me
