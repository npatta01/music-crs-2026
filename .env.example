# Copy to .env and fill in values as needed.
#
# HuggingFace authentication
# Option A (recommended): run `uvx hf auth login` once — token stored system-wide
#   at ~/.cache/huggingface/token, no .env needed.
# Option B (CI / Modal): set HF_TOKEN here.
#
# HF_TOKEN=hf_...

# Override HuggingFace cache location (default: ~/.cache/huggingface/).
# Useful if the home partition is small.
#
# HF_HOME=/path/to/larger/disk/.cache/huggingface

# ----- LiteLLM proxy (optional, see docs/litellm_proxy.md) -----
# Required to start ./scripts/litellm-proxy.
# OPENROUTER_API_KEY=sk-or-...

# Override the LiteLLM proxy base / key used by mcrs at runtime.
# Defaults: http://localhost:4000 and "sk-anything".
# LITELLM_PROXY_BASE=http://localhost:4000
# LITELLM_PROXY_KEY=sk-anything

# Override the proxy launcher's bind host/port and config path.
# LITELLM_PROXY_HOST=0.0.0.0
# LITELLM_PROXY_PORT=4000
# LITELLM_PROXY_CONFIG=configs/litellm_proxy.openrouter.yaml
